generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

enum ClientStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  FINISHED
  ARCHIVED
}

enum ServiceType {
  HOSTING
  DOMAIN
  MAINTENANCE
  SERVER
  LICENSE
  SUPPORT
  OTHER
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMI_YEARLY
  YEARLY
}

enum ServiceStatus {
  ACTIVE
  PAUSED
  CANCELLED
  ARCHIVED
}

enum BillingStatus {
  PLANNED
  DUE
  OVERDUE
  PAID
  CANCELLED
}

enum BillingSource {
  MANUAL
  SERVICE_AUTO
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum AccountType {
  CASH
  BANK
  CARD
  CRYPTO
  OTHER
}

enum NotificationStatus {
  SENT
  FAILED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TelegramBotType {
  FINANCE
  TASK
}

model User {
  id                          String   @id @default(cuid())
  email                       String   @unique
  passwordHash                String
  name                        String
  role                        UserRole @default(MEMBER)
  position                    String?
  telegram                    String?
  isActive                    Boolean  @default(true)
  telegramChatId              String?
  taskNotificationsEnabled    Boolean  @default(true)
  financeNotificationsEnabled Boolean  @default(false)
  locale                      String   @default("ru")
  currency                    String   @default("RUB")
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  assignedTasks Task[] @relation("TaskAssignee")
  createdTasks  Task[] @relation("TaskCreator")
  notes         Note[] @relation("NoteCreator")
}

model Client {
  id          String       @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  telegram    String?
  companyName String?
  taxId       String?
  notes       String?
  status      ClientStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  projects     Project[]
  services     Service[]
  billingItems BillingItem[]
  transactions Transaction[]
  noteItems    Note[]
}

model Project {
  id            String        @id @default(cuid())
  clientId      String
  name          String
  description   String?
  status        ProjectStatus @default(ACTIVE)
  startDate     DateTime?
  endDate       DateTime?
  repositoryUrl String?
  productionUrl String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  client       Client        @relation(fields: [clientId], references: [id])
  services     Service[]
  billingItems BillingItem[]
  transactions Transaction[]
  tasks        Task[]
  noteItems    Note[]
}

model Service {
  id               String        @id @default(cuid())
  clientId         String
  projectId        String?
  title            String
  description      String?
  type             ServiceType
  billingCycle     BillingCycle
  amount           Decimal       @db.Decimal(12, 2)
  currency         String        @default("RUB")
  nextDueDate      DateTime
  startDate        DateTime?
  endDate          DateTime?
  autoCreateIncome Boolean       @default(true)
  status           ServiceStatus @default(ACTIVE)
  notes            String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  client           Client            @relation(fields: [clientId], references: [id])
  project          Project?          @relation(fields: [projectId], references: [id])
  billingItems     BillingItem[]
  transactions     Transaction[]
  notificationLogs NotificationLog[]
}

model BillingItem {
  id        String        @id @default(cuid())
  clientId  String
  projectId String?
  serviceId String?
  title     String
  amount    Decimal       @db.Decimal(12, 2)
  currency  String        @default("RUB")
  dueDate   DateTime
  paidAt    DateTime?
  status    BillingStatus @default(PLANNED)
  source    BillingSource @default(MANUAL)
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  client           Client            @relation(fields: [clientId], references: [id])
  project          Project?          @relation(fields: [projectId], references: [id])
  service          Service?          @relation(fields: [serviceId], references: [id])
  transaction      Transaction?
  notificationLogs NotificationLog[]

  @@unique([serviceId, dueDate])
}

model Transaction {
  id            String          @id @default(cuid())
  type          TransactionType
  amount        Decimal         @db.Decimal(12, 2)
  currency      String          @default("RUB")
  date          DateTime
  categoryId    String?
  clientId      String?
  projectId     String?
  serviceId     String?
  billingItemId String?         @unique
  accountId     String?
  description   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  category    Category?    @relation(fields: [categoryId], references: [id])
  client      Client?      @relation(fields: [clientId], references: [id])
  project     Project?     @relation(fields: [projectId], references: [id])
  service     Service?     @relation(fields: [serviceId], references: [id])
  billingItem BillingItem? @relation(fields: [billingItemId], references: [id])
  account     Account?     @relation(fields: [accountId], references: [id])
}

model Category {
  id        String          @id @default(cuid())
  name      String
  type      TransactionType
  color     String?
  isSystem  Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  transactions Transaction[]
}

model Account {
  id             String      @id @default(cuid())
  name           String
  type           AccountType
  currency       String      @default("RUB")
  openingBalance Decimal     @default(0) @db.Decimal(12, 2)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  transactions Transaction[]
}

model TelegramSettings {
  id                     String   @id @default(cuid())
  chatId                 String?
  isEnabled              Boolean  @default(false)
  reminderDaysBefore     Json     @default("[7,3,1,0]")
  overdueReminderEnabled Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model NotificationLog {
  id            String             @id @default(cuid())
  reminderType  String
  serviceId     String?
  billingItemId String?
  sentAt        DateTime           @default(now())
  channel       String             @default("TELEGRAM")
  status        NotificationStatus
  errorMessage  String?

  service     Service?     @relation(fields: [serviceId], references: [id])
  billingItem BillingItem? @relation(fields: [billingItemId], references: [id])
}

model TelegramBotSettings {
  id          String          @id @default(cuid())
  type        TelegramBotType @unique
  botToken    String          @default("")
  botUsername String?
  isEnabled   Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Task {
  id           String       @id @default(cuid())
  projectId    String
  title        String
  description  String?
  status       TaskStatus   @default(TODO)
  priority     TaskPriority @default(MEDIUM)
  assigneeId   String?
  createdById  String?
  plannedStart DateTime?
  plannedEnd   DateTime?
  dueDate      DateTime?
  completedAt  DateTime?
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  project   Project @relation(fields: [projectId], references: [id])
  assignee  User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy User?   @relation("TaskCreator", fields: [createdById], references: [id])

  @@index([projectId])
  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  @@index([plannedStart])
  @@index([plannedEnd])
}

model Note {
  id          String   @id @default(cuid())
  title       String
  content     String
  clientId    String?
  projectId   String?
  createdById String
  isPinned    Boolean  @default(false)
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client    Client?  @relation(fields: [clientId], references: [id])
  project   Project? @relation(fields: [projectId], references: [id])
  createdBy User     @relation("NoteCreator", fields: [createdById], references: [id])

  @@index([createdById])
  @@index([clientId])
  @@index([projectId])
  @@index([isPinned])
  @@index([isArchived])
  @@index([updatedAt])
  @@index([title])
}
